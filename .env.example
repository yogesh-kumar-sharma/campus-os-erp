# Application
APP_NAME="College ERP Management System"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Module 2 will read and validate these settings.
DATABASE_URL=postgresql+asyncpg://college_erp:college_erp@localhost:5432/college_erp
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=college-erp-api
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
STORAGE_PATH=storage
MAX_UPLOAD_SIZE_MB=10
